<% if(success && success.length > 0){ %>

<script>

    Swal.fire({
        icon: 'success',
        title: 'Success',
        text: '<%= success[0] %>',
        timer: 2000,
        showConfirmButton: false
    });

</script>

<% } %>

<% if(error && error.length > 0){ %>

<script>

    Swal.fire({
        icon: 'error',
        title: 'Error',
        text: '<%= error[0] %>',
        timer: 2000,
        showConfirmButton: false
    });

</script>

<% } %>


